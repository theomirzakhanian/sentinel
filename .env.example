# VirusTotal API key: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# Hatching Triage API key: https://tria.ge/account/api
TRIAGE_API_KEY=
# Override only if you use the private cloud (default is the public one)
TRIAGE_BASE_URL=https://api.tria.ge/v0

# Claude Code CLI binary (must be on PATH)
SENTINEL_CLAUDE_BIN=claude

# MalwareBazaar API key (free, instant signup): https://bazaar.abuse.ch/account/
# Required for `sentinel fetch-malware` (their API now requires auth for ALL endpoints).
MALWAREBAZAAR_API_KEY=
